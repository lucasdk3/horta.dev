{
  "entities": {
    "Survey": {
      "title": "Survey",
      "description": "A research survey with defined questions.",
      "type": "object",
      "properties": {
        "title": { "type": "object", "description": "Localized map of titles" },
        "description": { "type": "object", "description": "Localized map of descriptions" },
        "questions": { "type": "array", "description": "List of questions" },
        "category": { "type": "string" },
        "tags": { "type": "array" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "questions", "active", "createdAt"]
    },
    "Response": {
      "title": "Response",
      "description": "A user response to a survey.",
      "type": "object",
      "properties": {
        "surveyId": { "type": "string" },
        "respondentId": { "type": "string" },
        "respondentEmail": { "type": "string" },
        "country": { "type": "string" },
        "answers": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["surveyId", "respondentId", "respondentEmail", "country", "answers", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile with gamification data.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "country": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isAdmin", "xp", "level"]
    },
    "SurveyRequest": {
      "title": "Survey Request",
      "description": "A request for a new survey suggested by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "suggestedCategory": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "requesterId", "status", "createdAt"]
    },
    "SurveyAnalysis": {
      "title": "Survey Analysis",
      "description": "Cached AI generated analysis for a survey.",
      "type": "object",
      "properties": {
        "surveyId": { "type": "string" },
        "lang": { "type": "string" },
        "countryFilter": { "type": "string" },
        "summary": { "type": "string", "description": "Markdown text" },
        "insights": { "type": "object", "description": "Structured JSON data" },
        "responseCount": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["surveyId", "lang", "countryFilter", "summary", "responseCount", "updatedAt"]
    }
  },
  "firestore": {
    "/surveys/{surveyId}": {
      "schema": "Survey",
      "description": "Collection of all surveys."
    },
    "/responses/{responseId}": {
      "schema": "Response",
      "description": "Collection of survey responses."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user metadata."
    },
    "/survey_requests/{requestId}": {
      "schema": "SurveyRequest",
      "description": "Collection of community requested surveys."
    },
    "/survey_analyses/{analysisId}": {
      "schema": "SurveyAnalysis",
      "description": "Cached AI analyses to optimize token usage."
    }
  }
}
